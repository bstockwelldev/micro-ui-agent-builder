# At least one LLM key is required for POST /api/agent/run and POST /api/agent/genui.
# Preferred: Google Gemini (JSON schema / GenUI); then Groq, OpenAI, or Vercel AI Gateway alone.
# Any of these enable Gemini (server reads NEXT_PUBLIC_* only — do not expose service keys to the client):
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_GENAI_API_KEY=
# NEXT_PUBLIC_GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
# Vercel AI Gateway — use flow model ids like gateway/meta/llama-3.3-70b or configure only this key.
AI_GATEWAY_API_KEY=

# Optional: durable studio store + backups on Supabase (Tabletop Studio project, schema agent_builder)
# Server-only — never expose SUPABASE_SERVICE_ROLE_KEY to the client.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
