# At least one LLM key is required for POST /api/agent/run and POST /api/agent/genui.
# Preferred: Google Gemini (JSON schema / GenUI); then Groq, OpenAI, or Vercel AI Gateway alone.
# Any of these enable Gemini (server reads NEXT_PUBLIC_* only — do not expose service keys to the client):
GOOGLE_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_GENAI_API_KEY=
# NEXT_PUBLIC_GEMINI_API_KEY=
GROQ_API_KEY=
# Optional registry providers (lib/ai-config.ts) — each is omitted until its key is set:
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
OPENAI_API_KEY=
# Optional overrides for flow knowledge embeddings (defaults: text-embedding-3-small, gemini-embedding-001)
# OPENAI_EMBEDDING_MODEL=
# GOOGLE_EMBEDDING_MODEL=
# Vercel AI Gateway — use flow model ids like gateway/meta/llama-3.3-70b or configure only this key.
AI_GATEWAY_API_KEY=

# Langfuse tracing (server-only)
# LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional (defaults to https://cloud.langfuse.com)
# LANGFUSE_BASEURL=

# Optional: Ollama (OpenAI-compatible API). Example: http://127.0.0.1:11434/v1 or http://localhost:11434
# Server normalizes base URL to include /v1. Flow LLM step may use ollama/<model> or set OLLAMA_MODEL.
OLLAMA_BASE_URL=
OLLAMA_MODEL=
# OLLAMA_API_KEY=ollama

# Supabase — URL is public; use anon (or publishable) key in the browser for OAuth + RLS clients.
# Server-only service role for admin/store APIs — never expose SUPABASE_SERVICE_ROLE_KEY to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias if your project uses the newer key name:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# When true, unauthenticated users are redirected to /login for studio routes (not /api/*).
# Enable Google and GitHub under Supabase → Authentication → Providers; add redirect URL:
#   https://<your-domain>/auth/callback
# AUTH_PROTECT_STUDIO=

# MCP (orchestrator) — see docs/mcp-multi-repo-rollout.md
# MCP_TOOL_RESOLUTION_ENABLED=true
# MCP_REGISTRY_FROM_SUPABASE=false
